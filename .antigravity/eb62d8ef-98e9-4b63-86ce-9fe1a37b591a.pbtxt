          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                          Authorized for production output"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        </h4>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        <p className=\"text-xs text-emerald-600 mt-0.5\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
