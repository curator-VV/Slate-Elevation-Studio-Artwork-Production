        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      if (!respRes.ok) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        const errorData = await respRes.json().catch(() => ({}));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        throw new Error(`Failed to load responses: ${errorData.error?.message || respRes.statusText}`);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const respData = await respRes.json();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const loadedResponses: FormResponseItem[] = respData.responses || [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
