    web_documents {
      url: "https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQG628wztpljpZAqd7yXL-WV9x-J23r4ULciPx27sIfCIcfjWqKLydNlw2KCdHT5bIhzuviNfXKDCuoDuPFhzTM4gxJgT5Nw6JW7G5LT6rpwCs0mXuz8ZIdjjQrztJdz47LOvC3wCHzEFid8JI9OW-qsHKsB22F0M57m-QeJKaYNyYC6rtRY86C91aZM3MQxlPSHGgh06AQ="
      title: "needle.app"
