    instruction: "Apply Clean Minimalism styling to the Header component"
    replacement_infos {
      original_chunk {
        target_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React from \'react\';\nimport { Sparkles, Image as ImageIcon, CheckCircle, Clock } from \'lucide-react\';\nimport { Artwork } from \'../types\';\n\ninterface HeaderProps {\n  artworks: Artwork[];\n  onUploadClick: () => void;\n  searchTerm: string;\n  setSearchTerm: (term: string) => void;\n  statusFilter: string;\n  setStatusFilter: (status: string) => void;\n}\n\nexport const Header: React.FC<HeaderProps> = ({\n  artworks,\n  onUploadClick,\n  searchTerm,\n  setSearchTerm,\n  statusFilter,\n  setStatusFilter,\n}) => {\n  const totalCount = artworks.length;\n  const pendingCount = artworks.filter(a => a.status === \'Pending Review\').length;\n  const draftedCount = artworks.filter(a => a.status === \'Changes Drafted\').length;\n  const approvedCount = artworks.filter(a => a.status === \'Approved for Production\').length;\n\n  return (\n    <header className=\"border-b border-[#e9e8e7] bg-[#fbf9f9]\">\n      {/* Top Brand Block */}\n      <div className=\"max-w-7xl mx-auto px-6 sm:px-8 py-8 flex flex-col md:flex-row md:items-end justify-between gap-6\">\n        <div>\n          <div className=\"text-[11px] font-bold uppercase tracking-[0.2em] text-[#6a5d43] font-sans mb-1.5 flex items-center gap-1.5\">\n            <Sparkles className=\"w-3.5 h-3.5 text-[#6a5d43]\" />\n            Internal Workshop Tool\n          </div>\n          <h1 className=\"text-3xl sm:text-4xl font-serif font-medium tracking-tight text-[#181919] leading-tight\">\n            Artwork Production Manager\n          </h1>\n          <p className=\"text-sm font-sans text-gray-500 mt-1 max-w-2xl\">\n            Review custom photo uploads, design print-spec configurations, draft corrections, and authorize museum-grade production outputs.\n          </p>\n        </div>\n\n        {/* Heavy Charcoal Primary Call to Action */}\n        <button\n          onClick={onUploadClick}\n          className=\"bg-[#181919] hover:bg-[#2c2d2c] text-white px-6 py-3 font-sans text-xs font-bold tracking-[0.1em] uppercase transition-all duration-150 flex items-center gap-2 rounded shadow-sm shrink-0 self-start md:self-end\"\n        >\n          <ImageIcon className=\"w-4 h-4\" />\n          Upload New Portrait\n        </button>\n      </div>\n\n      {/* Workshop Stats Board (Tonal Layering Cards) */}\n      <div className=\"max-w-7xl mx-auto px-6 sm:px-8 pb-8\">\n        <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n          <div className=\"bg-white border border-[#e8e6e1] p-4 rounded flex flex-col justify-between\">\n            <span className=\"text-[10px] font-bold font-sans uppercase tracking-wider text-gray-400\">Total Database</span>\n            <div className=\"flex items-baseline gap-2 mt-1\">\n              <span className=\"text-2xl font-serif font-medium text-gray-900\">{totalCount}</span>\n              <span className=\"text-xs text-gray-500\">Sketches</span>\n            </div>\n          </div>\n\n          <div className=\"bg-white border border-[#e8e6e1] p-4 rounded flex flex-col justify-between\">\n            <span className=\"text-[10px] font-bold font-sans uppercase tracking-wider text-amber-600 flex items-center gap-1\">\n              <Clock className=\"w-3 h-3\" /> PENDING REVIEW\n            </span>\n            <div className=\"flex items-baseline gap-2 mt-1\">\n              <span className=\"text-2xl font-serif font-medium text-gray-900\">{pendingCount}</span>\n              <span className=\"text-xs text-gray-500\">Awaiting specs</span>\n            </div>\n          </div>\n\n          <div className=\"bg-white border border-[#e8e6e1] p-4 rounded flex flex-col justify-between\">\n            <span className=\"text-[10px] font-bold font-sans uppercase tracking-wider text-[#6a5d43] flex items-center gap-1\">\n              <Clock className=\"w-3 h-3\" /> CHANGES DRAFTED\n            </span>\n            <div className=\"flex items-baseline gap-2 mt-1\">\n              <span className=\"text-2xl font-serif font-medium text-gray-900\">{draftedCount}</span>\n              <span className=\"text-xs text-gray-500\">In modification</span>\n            </div>\n          </div>\n\n          <div className=\"bg-white border border-[#e8e6e1] p-4 rounded flex flex-col justify-between\">\n            <span className=\"text-[10px] font-bold font-sans uppercase tracking-wider text-emerald-700 flex items-center gap-1\">\n              <CheckCircle className=\"w-3 h-3\" /> APPROVED FOR PROD.\n            </span>\n            <div className=\"flex items-baseline gap-2 mt-1\">\n              <span className=\"text-2xl font-serif font-medium text-emerald-700\">{approvedCount}</span>\n              <span className=\"text-xs text-emerald-600\">Ready to plot</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Dynamic Controls Bar */}\n        <div className=\"mt-8 pt-6 border-t border-[#e9e8e7] flex flex-col sm:flex-row items-center justify-between gap-4\">\n          {/* Work Search Field */}\n          <div className=\"w-full sm:w-80 relative\">\n            <input\n              type=\"text\"\n              placeholder=\"Search by SKU, Client, or Title...\"\n              value={searchTerm}\n              onChange={(e) => setSearchTerm(e.target.value)}\n              className=\"w-full bg-white border border-gray-300 rounded px-3 py-2 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:border-[#181919] transition-all\"\n            />\n          </div>\n\n          {/* Minimalist Filter Tab Chips */}\n          <div className=\"flex items-center gap-1 overflow-x-auto w-full sm:w-auto pb-1 sm:pb-0 scrollbar-none\">\n            {[\'All\', \'Pending Review\', \'Changes Drafted\', \'Approved for Production\'].map((status) => {\n              const count = status === \'All\' \n                ? totalCount \n                : artworks.filter(a => a.status === status).length;\n\n              const isSelected = statusFilter === status;\n\n              return (\n                <button\n                  key={status}\n                  onClick={() => setStatusFilter(status)}\n                  className={`px-3 py-1.5 text-xs font-semibold tracking-wide whitespace-nowrap rounded-full transition-all flex items-center gap-1.5 ${\n                    isSelected\n                      ? \'bg-[#6a5d43] text-white\'\n                      : \'bg-white hover:bg-gray-100 text-gray-600 border border-gray-200\'\n                  }`}\n                >\n                  {status}\n                  <span className={`text-[9px] px-1.5 py-0.5 rounded-full ${\n                    isSelected ? \'bg-white/20 text-white\' : \'bg-gray-100 text-gray-500 border border-gray-200/50\'\n                  }`}>\n                    {count}\n                  </span>\n                </button>\n              );\n            })}\n          </div>\n        </div>\n      </div>\n    </header>\n  );\n};"
        replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React from \'react\';\nimport { Sparkles, Image as ImageIcon, CheckCircle, Clock } from \'lucide-react\';\nimport { Artwork } from \'../types\';\n\ninterface HeaderProps {\n  artworks: Artwork[];\n  onUploadClick: () => void;\n  searchTerm: string;\n  setSearchTerm: (term: string) => void;\n  statusFilter: string;\n  setStatusFilter: (status: string) => void;\n}\n\nexport const Header: React.FC<HeaderProps> = ({\n  artworks,\n  onUploadClick,\n  searchTerm,\n  setSearchTerm,\n  statusFilter,\n  setStatusFilter,\n}) => {\n  const totalCount = artworks.length;\n  const pendingCount = artworks.filter(a => a.status === \'Pending Review\').length;\n  const draftedCount = artworks.filter(a => a.status === \'Changes Drafted\').length;\n  const approvedCount = artworks.filter(a => a.status === \'Approved for Production\').length;\n\n  return (\n    <header className=\"border-b border-gray-200 bg-white shadow-xs\">\n      {/* Top Brand Block */}\n      <div className=\"max-w-7xl mx-auto px-6 sm:px-8 py-6 flex flex-col md:flex-row md:items-center justify-between gap-6\">\n        <div>\n          {/* Pathway Navigation */}\n          <div className=\"flex items-center gap-2 mb-3 text-xs text-gray-500 font-sans\">\n            <div className=\"w-5 h-5 bg-blue-600 rounded flex items-center justify-center\">\n              <div className=\"w-2.5 h-2.5 border border-white rounded-xs\"></div>\n            </div>\n            <span className=\"font-bold text-gray-800 uppercase tracking-tight\">flow_spec</span>\n            <span className=\"text-gray-300\">/</span>\n            <span className=\"text-gray-500\">Internal Workspace</span>\n            <span className=\"text-gray-300\">/</span>\n            <span className=\"text-blue-600 font-medium\">Production Desk</span>\n          </div>\n\n          <h1 className=\"text-2xl sm:text-3xl font-sans font-extrabold tracking-tight text-gray-900 leading-none\">\n            Artwork Production Manager\n          </h1>\n          <p className=\"text-xs font-sans text-gray-500 mt-1 max-w-xl\">\n            System panel for uploading raw portraits, drafting specs, framing overlays, and authorizing full production plotters.\n          </p>\n        </div>\n\n        {/* Clean Blue Modern Action Button */}\n        <button\n          onClick={onUploadClick}\n          className=\"bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 font-sans text-xs font-bold tracking-wide uppercase transition-all duration-150 flex items-center gap-2 rounded-lg shadow-sm hover:shadow-md shrink-0 self-start md:self-center\"\n        >\n          <ImageIcon className=\"w-4 h-4\" />\n          + Upload Photo\n        </button>\n      </div>\n\n      {/* Workshop Stats Board (Tonal Layering Cards) */}\n      <div className=\"max-w-7xl mx-auto px-6 sm:px-8 pb-6\">\n        <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n          <div className=\"bg-gray-50 border border-gray-250/80 p-4 rounded-lg flex flex-col justify-between\">\n            <span className=\"text-[10px] font-bold font-sans uppercase tracking-wider text-gray-400\">Total Database</span>\n            <div className=\"flex items-baseline gap-2 mt-1\">\n              <span className=\"text-2xl font-sans font-extrabold text-gray-900\">{totalCount}</span>\n              <span className=\"text-xs text-gray-500\">files</span>\n            </div>\n          </div>\n\n          <div className=\"bg-gray-50 border border-gray-250/80 p-4 rounded-lg flex flex-col justify-between\">\n            <span className=\"text-[10px] font-bold font-sans uppercase tracking-wider text-amber-600 flex items-center gap-1\">\n              <Clock className=\"w-3 h-3\" /> PENDING REVIEW\n            </span>\n            <div className=\"flex items-baseline gap-2 mt-1\">\n              <span className=\"text-2xl font-sans font-extrabold text-amber-600\">{pendingCount}</span>\n              <span className=\"text-xs text-gray-500\">needs specs</span>\n            </div>\n          </div>\n\n          <div className=\"bg-gray-50 border border-gray-250/80 p-4 rounded-lg flex flex-col justify-between\">\n            <span className=\"text-[10px] font-bold font-sans uppercase tracking-wider text-blue-600 flex items-center gap-1\">\n              <Clock className=\"w-3 h-3\" /> CHANGES DRAFTED\n            </span>\n            <div className=\"flex items-baseline gap-2 mt-1\">\n              <span className=\"text-2xl font-sans font-extrabold text-blue-600\">{draftedCount}</span>\n              <span className=\"text-xs text-gray-500\">revisions</span>\n            </div>\n          </div>\n\n          <div className=\"bg-gray-50 border border-gray-250/80 p-4 rounded-lg flex flex-col justify-between\">\n            <span className=\"text-[10px] font-bold font-sans uppercase tracking-wider text-emerald-700 flex items-center gap-1\">\n              <CheckCircle className=\"w-3 h-3\" /> APPROVED FOR PROD.\n            </span>\n            <div className=\"flex items-baseline gap-2 mt-1\">\n              <span className=\"text-2xl font-sans font-extrabold text-emerald-700\">{approvedCount}</span>\n              <span className=\"text-xs text-emerald-600\">ready to plot</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Dynamic Controls Bar */}\n        <div className=\"mt-6 pt-6 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between gap-4\">\n          {/* Work Search Field */}\n          <div className=\"w-full sm:w-80 relative\">\n            <input\n              type=\"text\"\n              placeholder=\"Search by SKU, Client, or Title...\"\n              value={searchTerm}\n              onChange={(e) => setSearchTerm(e.target.value)}\n              className=\"w-full bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-800 placeholder-gray-450 focus:outline-none focus:border-blue-600 focus:ring-1 focus:ring-blue-600 transition-all font-sans\"\n            />\n          </div>\n\n          {/* Minimalist Filter Tab Chips */}\n          <div className=\"flex items-center gap-1 overflow-x-auto w-full sm:w-auto pb-1 sm:pb-0 scrollbar-none\">\n            {[\'All\', \'Pending Review\', \'Changes Drafted\', \'Approved for Production\'].map((status) => {\n              const count = status === \'All\' \n                ? totalCount \n                : artworks.filter(a => a.status === status).length;\n\n              const isSelected = statusFilter === status;\n\n              return (\n                <button\n                  key={status}\n                  onClick={() => setStatusFilter(status)}\n                  className={`px-3 py-1.5 text-xs font-semibold tracking-wide whitespace-nowrap rounded-lg transition-all flex items-center gap-1.5 ${\n                    isSelected\n                      ? \'bg-blue-50 text-blue-700 border border-blue-200 font-bold\'\n                      : \'bg-white hover:bg-gray-50 text-gray-600 border border-gray-250\'\n                  }`}\n                >\n                  {status}\n                  <span className={`text-[9px] px-1.5 py-0.5 rounded-full ${\n                    isSelected ? \'bg-blue-205 text-blue-700 font-bold bg-blue-100\' : \'bg-gray-100 text-gray-500 border border-gray-200/50\'\n                  }`}>\n                    {count}\n                  </span>\n                </button>\n              );\n            })}\n          </div>\n        </div>\n      </div>\n    </header>\n  );\n};"
