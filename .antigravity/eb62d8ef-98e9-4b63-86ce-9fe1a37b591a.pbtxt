          text: "                  {/* Status Toggle control block */}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                  <div>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    <label className=\"block text-[10px] font-bold tracking-wider font-sans uppercase text-gray-500 mb-2\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      Workflow Status"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    </label>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    <div className=\"grid grid-cols-3 gap-2\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      {([\'Pending Review\', \'Changes Drafted\', \'Approved for Production\'] as ArtworkStatus[]).map((statusVal) => {"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        const isCurrent = selectedArtwork.status === statusVal;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        return ("
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                          <button"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                            key={statusVal}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                            type=\"button\""
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                            onClick={() => handleUpdateActiveSpecs({ status: statusVal })}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                            className={`px-2 py-2 text-[11px] font-bold uppercase tracking-wider rounded border text-center transition-all ${"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                            className={`px-2 py-2 text-[11px] font-bold uppercase tracking-wider rounded-lg border text-center transition-all ${"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                              isCurrent"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                ? statusVal === \'Approved for Production\'"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                  ? \'bg-emerald-600 border-emerald-600 text-white shadow-xs\'"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                  ? \'bg-emerald-600 border-emerald-600 text-white shadow-sm font-bold\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                  : statusVal === \'Changes Drafted\'"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                                  ? \'bg-[#6a5d43] border-[#6a5d43] text-white shadow-xs\'"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                  : \'bg-amber-600 border-amber-600 text-white shadow-xs\'"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                : \'bg-transparent border-gray-200 text-gray-600 hover:border-gray-300\'"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                            }`}"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                          >"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                            {statusVal.replace(\' for Production\', \'\')}"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                                  ? \'bg-blue-600 border-blue-600 text-white shadow-sm font-bold\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                  : \'bg-amber-500 border-amber-500 text-white shadow-sm font-bold\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                : \'bg-transparent border-gray-250 text-gray-650 hover:bg-gray-50 hover:border-gray-450\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                            }`}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          >"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                            {statusVal === \'Changes Drafted\' ? \'In Revision\' : statusVal === \'Pending Review\' ? \'Needs Spec\' : \'Approved\'}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                          </button>"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                        );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      })}"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
