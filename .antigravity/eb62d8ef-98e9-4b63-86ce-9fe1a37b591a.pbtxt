        }
        lines {
          text: "  const getAnswerValue = (response: FormResponseItem, questionId: string): string => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (!response.answers || !questionId) return \'\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
