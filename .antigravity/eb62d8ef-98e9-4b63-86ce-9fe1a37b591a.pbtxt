          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                    <div className=\"bg-emerald-50 border border-emerald-200 rounded p-4 flex items-center gap-3\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "                      <span className=\"p-2 rounded-full bg-emerald-100 text-emerald-700\">"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
