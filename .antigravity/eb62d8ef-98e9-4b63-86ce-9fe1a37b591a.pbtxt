  file_change {
    absolute_path_uri: "file:///src/utils/canvasExporter.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { Artwork } from \'../types\';\n\nexport function downloadFile(url: string, filename: string) {\n  const link = document.createElement(\'a\');\n  link.href = url;\n  link.download = filename;\n  document.body.appendChild(link);\n  link.click();\n  document.body.removeChild(link);\n}\n\nexport function downloadSpecSheet(artwork: Artwork) {\n  const content = `=========================================\nARTWORK PRODUCTION SPECIFICATION\n=========================================\nReference Order ID: ${artwork.referenceNumber}\nProduction Status:  ${artwork.status.toUpperCase()}\nLast Modified:      ${new Date(artwork.lastModified).toLocaleString()}\n\nTITLE AND CLIENT\n-----------------------------------------\nArtwork Title:      ${artwork.title}\nClient Name:        ${artwork.clientName}\n\nPRODUCTION SELECTIONS\n-----------------------------------------\nArt Style:          ${artwork.style}\nPrint Dimensions:   ${artwork.dimensions}\nMat Board Width:    ${artwork.matWidth}\nFrame Molding:      ${artwork.frame}\n\nPRODUCTION DIRECTIONS & REVIEWS Notes\n-----------------------------------------\n${artwork.notes || \"No special production directions entered.\"}\n\n=========================================\nPrepared for workshop execution.\nGallery Minimalist Production System.\n=========================================`;\n\n  const blob = new Blob([content], { type: \'text/plain;charset=utf-8\' });\n  const url = URL.createObjectURL(blob);\n  downloadFile(url, `SPEC-${artwork.referenceNumber}-${artwork.title.replace(/\\s+/g, \'_\')}.txt`);\n  URL.revokeObjectURL(url);\n}\n\n// Generates an interactive framed image mock on canvas and triggers download\nexport function exportFramedArtwork(artwork: Artwork): Promise<boolean> {\n  return new Promise((resolve) => {\n    const img = new Image();\n    // Resolve cross-origin issues for hotlinked images\n    if (artwork.imageData.startsWith(\'http\')) {\n      img.crossOrigin = \'anonymous\';\n    }\n    img.src = artwork.imageData;\n\n    img.onload = () => {\n      try {\n        const canvas = document.createElement(\'canvas\');\n        const ctx = canvas.getContext(\'2d\');\n        if (!ctx) {\n          resolve(false);\n          return;\n        }\n\n        // Base resolution\n        const aspect = img.width / img.height;\n        const imgTargetWidth = 1200;\n        const imgTargetHeight = imgTargetWidth / aspect;\n\n        // Calc mat padding relative to image size\n        let matPaddingPX = 0;\n        if (artwork.matWidth === \'1 inch\') matPaddingPX = 80;\n        else if (artwork.matWidth === \'2 inches\') matPaddingPX = 150;\n        else if (artwork.matWidth === \'3 inches\') matPaddingPX = 220;\n\n        // Calc frame width\n        let frameWidthPX = 0;\n        if (artwork.frame !== \'None\') {\n          frameWidthPX = 60; // Thicker premium frame\n        }\n\n        // Info board at bottom of mockup sheet (helps production matching)\n        const infoBarHeight = 160;\n\n        // Total canvas size\n        canvas.width = imgTargetWidth + (matPaddingPX * 2) + (frameWidthPX * 2);\n        canvas.height = imgTargetHeight + (matPaddingPX * 2) + (frameWidthPX * 2) + infoBarHeight;\n\n        // 1. Draw outer frame background / texture color\n        ctx.fillStyle = \'#FFFFFF\';\n        ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n        // Draw frame border\n        if (artwork.frame !== \'None\') {\n          // Frame colors matching \"Gallery Minimalist\" specs\n          let frameColor = \'#181919\'; // Charcoal\n          if (artwork.frame === \'Natural Oak\') frameColor = \'#d6c5a5\'; // Soft Wood Light Oak\n          else if (artwork.frame === \'Warm Walnut\') frameColor = \'#51452d\'; // Dark Warm Wood Walnut\n          else if (artwork.frame === \'Gallery Gold\') frameColor = \'#c5a363\'; // Antique Brass Gold\n\n          ctx.fillStyle = frameColor;\n          ctx.fillRect(0, 0, canvas.width, canvas.height - infoBarHeight);\n\n          // Wood grain or inner highlights hint (fine outlines)\n          ctx.strokeStyle = \'rgba(0, 0, 0, 0.15)\';\n          ctx.lineWidth = 4;\n          ctx.strokeRect(2, 2, canvas.width - 4, canvas.height - infoBarHeight - 4);\n          ctx.strokeRect(10, 10, canvas.width - 20, canvas.height - infoBarHeight - 20);\n        }\n\n        // 2. Draw Mat Board (the matting paper)\n        const matX = frameWidthPX;\n        const matY = frameWidthPX;\n        const matW = canvas.width - (frameWidthPX * 2);\n        const matH = canvas.height - (frameWidthPX * 2) - infoBarHeight;\n\n        ctx.fillStyle = \'#fdfcfb\'; // Soft premium watercolor/mat paper white\n        ctx.fillRect(matX, matY, matW, matH);\n\n        // Core mat cutout bevel shadow\n        ctx.fillStyle = \'rgba(0,0,0,0.06)\';\n        ctx.fillRect(matX + matPaddingPX - 4, matY + matPaddingPX - 4, imgTargetWidth + 8, imgTargetHeight + 8);\n        ctx.fillStyle = \'#faf8f5\';\n        ctx.fillRect(matX + matPaddingPX - 2, matY + matPaddingPX - 2, imgTargetWidth + 4, imgTargetHeight + 4);\n\n        // Draw fine inner mat bevel cutoff line\n        ctx.strokeStyle = \'#e3e1db\';\n        ctx.lineWidth = 1;\n        ctx.strokeRect(matX + matPaddingPX - 1, matY + matPaddingPX - 1, imgTargetWidth + 2, imgTargetHeight + 2);\n\n        // 3. Draw original image onto canvas inside mat board\n        ctx.drawImage(img, matX + matPaddingPX, matY + matPaddingPX, imgTargetWidth, imgTargetHeight);\n\n        // 4. Drawer Spec Board / Production Label at the bottom\n        const specY = canvas.height - infoBarHeight;\n        ctx.fillStyle = \'#181919\'; // Charcoal background for the production label\n        ctx.fillRect(0, specY, canvas.width, infoBarHeight);\n\n        // Divider\n        ctx.fillStyle = \'#6a5d43\'; // Wood Accent\n        ctx.fillRect(0, specY, canvas.width, 4);\n\n        // Grid text metadata styling\n        ctx.fillStyle = \'#FFFFFF\';\n        ctx.font = \'bold 22px system-ui, -apple-system, sans-serif\';\n        ctx.fillText(`ORDER REF: ${artwork.referenceNumber}`, 40, specY + 50);\n\n        ctx.font = \'20px system-ui, -apple-system, sans-serif\';\n        ctx.fillStyle = \'#949493\'; // Muted on-charcoal text\n        ctx.fillText(`TITLE: `, 40, specY + 95);\n        ctx.fillStyle = \'#FFFFFF\';\n        ctx.font = \'bold 20px system-ui, -apple-system, sans-serif\';\n        ctx.fillText(artwork.title.toUpperCase(), 110, specY + 95);\n\n        ctx.font = \'20px system-ui, -apple-system, sans-serif\';\n        ctx.fillStyle = \'#949493\';\n        ctx.fillText(`CLIENT: `, 40, specY + 135);\n        ctx.fillStyle = \'#FFFFFF\';\n        ctx.font = \'bold 20px system-ui, -apple-system, sans-serif\';\n        ctx.fillText(artwork.clientName, 130, specY + 135);\n\n        // Right side Specs\n        const rightColX = canvas.width - 450;\n        ctx.font = \'20px system-ui, -apple-system, sans-serif\';\n        ctx.fillStyle = \'#949493\';\n        ctx.fillText(`DIMENSIONS: `, rightColX, specY + 50);\n        ctx.fillStyle = \'#FFFFFF\';\n        ctx.font = \'bold 20px system-ui, -apple-system, sans-serif\';\n        ctx.fillText(artwork.dimensions, rightColX + 150, specY + 50);\n\n        ctx.font = \'20px system-ui, -apple-system, sans-serif\';\n        ctx.fillStyle = \'#949493\';\n        ctx.fillText(`PRINT STYLE: `, rightColX, specY + 95);\n        ctx.fillStyle = \'#FFFFFF\';\n        ctx.font = \'bold 20px system-ui, -apple-system, sans-serif\';\n        ctx.fillText(artwork.style, rightColX + 150, specY + 95);\n\n        ctx.font = \'20px system-ui, -apple-system, sans-serif\';\n        ctx.fillStyle = \'#949493\';\n        ctx.fillText(`FRAMING SEC: `, rightColX, specY + 135);\n        ctx.fillStyle = \'#FFFFFF\';\n        ctx.font = \'bold 20px system-ui, -apple-system, sans-serif\';\n        const matDesc = artwork.matWidth === \'None\' ? \'No Mat\' : `${artwork.matWidth} Mat`;\n        const frameDesc = artwork.frame === \'None\' ? \'No Frame\' : `${artwork.frame} Frame`;\n        ctx.fillText(`${frameDesc} / ${matDesc}`, rightColX + 150, specY + 135);\n\n        // Production Approved stamp\n        if (artwork.status === \'Approved for Production\') {\n          const stampX = canvas.width - 240;\n          ctx.save();\n          ctx.translate(stampX, specY + 80);\n          ctx.rotate(-0.06);\n\n          // Draw rubber stamp border red/terracotta\n          ctx.strokeStyle = \'#ba1a1a\';\n          ctx.lineWidth = 3;\n          ctx.strokeRect(-90, -45, 180, 80);\n\n          ctx.fillStyle = \'#ba1a1a\';\n          ctx.font = \'bold 22px system-ui, -apple-system, sans-serif\';\n          ctx.textAlign = \'center\';\n          ctx.fillText(\'APPROVED\', 0, -10);\n          ctx.font = \'bold 15px system-ui, -apple-system, sans-serif\';\n          ctx.fillText(\'FOR PRODUCTION\', 0, 20);\n          ctx.restore();\n        } else {\n          // Stamp \"DRAFT ONLY\" / \"SPECIFICATION SHEET\"\n          const stampX = canvas.width - 240;\n          ctx.save();\n          ctx.translate(stampX, specY + 80);\n          ctx.rotate(-0.06);\n\n          ctx.strokeStyle = \'#6a5d43\';\n          ctx.lineWidth = 3;\n          ctx.strokeRect(-95, -45, 190, 80);\n\n          ctx.fillStyle = \'#6a5d43\';\n          ctx.font = \'bold 22px system-ui, -apple-system, sans-serif\';\n          ctx.textAlign = \'center\';\n          ctx.fillText(\'WORK IN\', 0, -10);\n          ctx.font = \'bold 16px system-ui, -apple-system, sans-serif\';\n          ctx.fillText(\'PROGRESS\', 0, 20);\n          ctx.restore();\n        }\n\n        // Trigger down\n        const finalUrl = canvas.toDataURL(\'image/jpeg\', 0.95);\n        downloadFile(finalUrl, `framed-production-spec-${artwork.referenceNumber}-${artwork.title.replace(/\\s+/g, \'_\')}.jpg`);\n        resolve(true);\n      } catch (err) {\n        console.error(\'Failed to create framed canvas mock. Falling back to downloading original.\', err);\n        // Fallback: download original image file directly\n        downloadFile(artwork.imageData, `original-${artwork.referenceNumber}-${artwork.title.replace(/\\s+/g, \'_\')}.jpg`);\n        resolve(false);\n      }\n    };\n\n    img.onerror = () => {\n      // In case of any cross-origin error, download the original image, or open in new tab\n      try {\n        downloadFile(artwork.imageData, `original-${artwork.referenceNumber}-${artwork.title.replace(/\\s+/g, \'_\')}.jpg`);\n        resolve(true);\n      } catch (e) {\n        window.open(artwork.imageData, \'_blank\');\n        resolve(false);\n      }\n    };\n  });\n}\n"
    }
