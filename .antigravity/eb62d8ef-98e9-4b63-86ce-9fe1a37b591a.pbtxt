          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "                      className=\"w-full bg-emerald-600 hover:bg-emerald-700 text-white font-sans text-xs font-bold tracking-[0.15em] uppercase py-3.5 rounded-lg transition-all duration-200 flex items-center justify-center gap-2 shadow-lg shadow-emerald-200 hover:shadow-xl\""
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
